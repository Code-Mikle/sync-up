LOCAL_SERVER_PORT=


# Product Config
LOCAL_MYSQL_HOST=localhost
LOCAL_MYSQL_PORT=3306
LOCAL_MYSQL_USERNAME=root
LOCAL_MYSQL_PASSWORD=

LOCAL_REDIS_HOST=localhost
LOCAL_REDIS_PORT=6379
LOCAL_REDIS_PASSWORD=

LOCAL_SERVER_PORT=8080

# Optional AI agent config. It is disabled by default.
SYNC_UP_AI_AGENT_ENABLED=false
SYNC_UP_AI_AGENT_MODEL=qwen3.6-flash-2026-04-16
SYNC_UP_AI_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
SYNC_UP_AI_AGENT_TIMEOUT_MS=8000
SYNC_UP_AI_AGENT_MAX_TOOL_CALLS=3
SYNC_UP_AI_MEMORY_ENABLED=true
SYNC_UP_AI_MEMORY_MAX_MESSAGES=20
SYNC_UP_AI_MEMORY_REDIS_TTL_HOURS=12
SYNC_UP_AI_MEMORY_MYSQL_TTL_HOURS=24

# Production values should be injected by the deployment environment.
# PROD_MYSQL_URL=jdbc:mysql://127.0.0.1:3306/sync_up_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC
