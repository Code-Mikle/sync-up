
# Local Config
# MySQL
LOCAL_MYSQL_HOST=
LOCAL_MYSQL_PORT=
LOCAL_MYSQL_USERNAME=
LOCAL_MYSQL_PASSWORD=
# Redis
LOCAL_REDIS_HOST=
LOCAL_REDIS_PORT=
